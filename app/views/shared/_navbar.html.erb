<nav class="bg-white border-b border-gray-100">
  <div class="mx-auto max-w-7xl px-6 sm:px-8 lg:px-10">
    <div class="flex h-20 items-center justify-between">
      <!-- Left section -->
      <div class="flex items-center">
        <!-- Logo -->
        <div class="flex-shrink-0">
          <svg class="h-9 w-9 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>

        <!-- Desktop Navigation -->
        <div class="hidden sm:ml-10 sm:flex sm:space-x-8">
          <%= link_to "Dashboard", root_path, 
              class: "text-gray-900 hover:text-indigo-600 hover:bg-indigo-50 inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200 #{current_page?(root_path) ? 'bg-indigo-50 text-indigo-600' : ''}" %>
          <%= link_to "Applications", "#",
              class: "text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200 #{current_page?('#') ? 'bg-indigo-50 text-indigo-600' : ''}" %>
           <%= link_to "Databases", "#",
              class: "text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200 #{current_page?('#') ? 'bg-indigo-50 text-indigo-600' : ''}" %>
          <%= link_to "Backups", "#",
              class: "text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200 #{current_page?('#') ? 'bg-indigo-50 text-indigo-600' : ''}" %>
          </div>
      </div>

      <!-- Right section -->
      <div class="flex items-center space-x-6">
        <%= link_to "Documentation", "#",
              class: "text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200 #{current_page?('#') ? 'bg-indigo-50 text-indigo-600' : ''}" %>
        
        <!-- Notification bell -->
        <button type="button" class="text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 p-2 rounded-md transition-colors duration-200 relative">
          <span class="sr-only">View notifications</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
          </svg>
          <span class="absolute top-0 right-0 block h-2 w-2 rounded-full bg-indigo-600 ring-2 ring-white"></span>
        </button>

        <!-- Settings gear -->
        <%= link_to edit_setup_path, class: "text-gray-400 hover:text-indigo-600 hover:bg-indigo-50 p-2 rounded-md transition-colors duration-200 #{current_page?(edit_setup_path) ? 'bg-indigo-50 text-indigo-600' : ''}" do %>
          <span class="sr-only">Server settings</span>
          <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        <% end %>

        <!-- Sign out button -->
        <%= link_to "#", class: "text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 inline-flex items-center px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200" do %>
          <span class="sr-only">Sign out</span>
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
        <% end %>

        <!-- Mobile menu button -->
        <button type="button" class="text-gray-500 hover:text-indigo-600 hover:bg-indigo-50 p-2 rounded-md sm:hidden transition-colors duration-200" aria-controls="mobile-menu" aria-expanded="false">
          <span class="sr-only">Open main menu</span>
          <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="sm:hidden" id="mobile-menu">
    <div class="space-y-2 pb-4 pt-3">
      <%= link_to "Dashboard", root_path, 
          class: "bg-indigo-50 text-indigo-600 block px-5 py-3 text-sm font-medium rounded-md" %>
      <%= link_to "Team", "#",
          class: "text-gray-600 hover:bg-indigo-50 hover:text-indigo-600 block px-5 py-3 text-sm font-medium rounded-md transition-colors duration-200" %>
      <%= link_to "Projects", "#",
          class: "text-gray-600 hover:bg-indigo-50 hover:text-indigo-600 block px-5 py-3 text-sm font-medium rounded-md transition-colors duration-200" %>
      <%= link_to "Calendar", "#",
          class: "text-gray-600 hover:bg-indigo-50 hover:text-indigo-600 block px-5 py-3 text-sm font-medium rounded-md transition-colors duration-200" %>
      <%= link_to "Server Settings", edit_setup_path,
          class: "text-gray-600 hover:bg-indigo-50 hover:text-indigo-600 block px-5 py-3 text-sm font-medium rounded-md transition-colors duration-200" %>
    </div>
  </div>
</nav> 