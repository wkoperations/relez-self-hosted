<div class="relative flex items-center space-x-3 rounded-lg border border-gray-200 bg-white px-6 py-5 hover:border-gray-300 hover:shadow">
  <div class="flex-shrink-0">
    <div class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600">
      <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
      </svg>
    </div>
  </div>
  <div class="min-w-0 flex-1">
    <div class="flex items-center justify-between">
      <p class="text-sm font-medium text-gray-900"><%= app.name %></p>
    </div>
    <p class="truncate text-sm text-gray-500"><%= app.image %></p>
  </div>
  <div class="flex-shrink-0">
    <div class="flex items-center space-x-2">
      <% if app.system %>
        <span class="inline-flex items-center rounded-full bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-700/10">System</span>
      <% end %>
      <%= link_to "#", class: "text-gray-400 hover:text-gray-500" do %>
        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
          <path d="M10 12a2 2 0 100-4 2 2 0 000 4z" />
          <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd" />
        </svg>
      <% end %>

      <% unless app.system %>
        <%= link_to "#", class: "text-gray-400 hover:text-gray-500" do %>
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
          </svg>
        <% end %>

        <%= link_to "#", class: "text-gray-400 hover:text-gray-500" do %>
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
          </svg>
        <% end %>
      <% end %>
    </div>
  </div>
</div> 