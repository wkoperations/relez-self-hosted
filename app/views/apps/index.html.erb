<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
  <div class="border-b border-gray-200 pb-5">
    <div class="sm:flex sm:items-center sm:justify-between">
      <div>
        <h1 class="text-2xl font-semibold leading-6 text-gray-900">Apps</h1>
        <p class="mt-2 max-w-4xl text-sm text-gray-500">Manage your applications and system components. Create new apps to extend the platform's functionality.</p>
      </div>
      <div class="mt-3 flex sm:ml-4 sm:mt-0">
        <%= link_to "#", class: "inline-flex items-center rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50" do %>
          <svg class="-ml-0.5 mr-1.5 h-5 w-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
          </svg>
          Import
        <% end %>
        <%= link_to "#", class: "ml-3 inline-flex items-center rounded-md bg-indigo-600 px-3 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" do %>
          <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Create new app
        <% end %>
      </div>
    </div>
  </div>

  <% if @user_apps.any? %>
    <div class="mt-8">
      <div class="sm:flex sm:items-center">
        <div class="sm:flex-auto">
          <h2 class="text-base font-semibold leading-6 text-gray-900">Your Apps</h2>
          <p class="mt-2 text-sm text-gray-700">Custom apps that you've added to the system.</p>
        </div>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        <%= render partial: "app_card", collection: @user_apps, as: :app %>
        
        <%= link_to "#", class: "relative flex items-center space-x-3 rounded-lg border border-gray-200 bg-white px-6 py-5 hover:border-gray-300 hover:shadow" do %>
          <div class="flex-shrink-0">
            <div class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600">
              <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
              </svg>
            </div>
          </div>
          <div class="min-w-0 flex-1">
            <span class="absolute inset-0" aria-hidden="true"></span>
            <p class="text-sm font-medium text-gray-900">Create new app</p>
            <p class="truncate text-sm text-gray-500">Add a new application</p>
          </div>
        <% end %>
      </div>
    </div>
  <% else %>
    <div class="mt-8 text-center">
      <div class="mx-auto max-w-2xl">
        <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" />
        </svg>
        <h2 class="mt-2 text-base font-semibold leading-6 text-gray-900">Get started by creating your first app</h2>
        <p class="mt-1 text-sm text-gray-500">Add your first application to get started with the platform. You can add more apps later.</p>
        <div class="mt-6">
          <%= link_to "#", class: "inline-flex items-center rounded-md bg-indigo-600 px-3.5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" do %>
            <svg class="-ml-0.5 mr-1.5 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
            </svg>
            Create your first app
          <% end %>
        </div>
      </div>
    </div>
  <% end %>

  <% if @system_apps.any? %>
    <div class="mt-8">
      <div class="sm:flex sm:items-center">
        <div class="sm:flex-auto">
          <h2 class="text-base font-semibold leading-6 text-gray-900">System Apps</h2>
          <p class="mt-2 text-sm text-gray-700">Required system components that cannot be modified or deleted.</p>
        </div>
      </div>
      <div class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
        <%= render partial: "app_card", collection: @system_apps, as: :app %>
      </div>
    </div>
  <% end %>
</div> 