<%= form_with model: form, url: form.persisted? ? setup_path : setup_path, scope: :setup, class: "space-y-6" do |f| %>
  <% if form.errors.any? %>
    <div class="rounded-md bg-red-50 p-4">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-medium text-red-800">
            <%= pluralize(form.errors.count, "error") %> prevented setup from being saved:
          </h3>
          <div class="mt-2 text-sm text-red-700">
            <ul class="list-disc pl-5 space-y-1">
              <% form.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div>
    <%= f.label :hostname, "Server Hostname", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= f.text_field :hostname, class: "block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <p class="mt-2 text-sm text-gray-500">The hostname for this server (e.g., app-server-01.example.com)</p>
  </div>

  <div>
    <%= f.label :admin_email, "Admin Email", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= f.email_field :admin_email, class: "block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <p class="mt-2 text-sm text-gray-500">The email address for the server administrator</p>
  </div>

  <div>
    <%= f.label :timezone, "Server Timezone", class: "block text-sm font-medium text-gray-700" %>
    <div class="mt-1">
      <%= f.time_zone_select :timezone, nil, {}, { class: "block w-full rounded-md border border-gray-300 px-3 py-2 shadow-sm focus:border-indigo-500 focus:outline-none focus:ring-indigo-500 sm:text-sm appearance-none" } %>
    </div>
    <p class="mt-2 text-sm text-gray-500">The timezone for this server</p>
  </div>

  <div>
    <%= f.submit form.persisted? ? "Update Settings" : "Complete Setup", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500" %>
  </div>
<% end %> 