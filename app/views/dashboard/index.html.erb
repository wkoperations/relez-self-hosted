<%# Quick Actions %>
<div class="mt-8">
  <div class="mx-auto max-w-7xl">
    <h2 class="text-base font-semibold leading-6 text-gray-900">Cluster Actions</h2>
    <div class="mt-5 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <%= link_to "#", class: "relative flex items-center space-x-3 rounded-lg border border-gray-200 bg-white px-6 py-5 hover:border-gray-300 hover:shadow" do %>
        <div class="flex-shrink-0">
          <div
            class="
              inline-flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600
            "
          >
            <svg
              class="h-6 w-6 text-white"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 4.5v15m7.5-7.5h-15"
              />
            </svg>
          </div>
        </div>
        <div class="min-w-0 flex-1">
          <span class="absolute inset-0" aria-hidden="true"></span>
          <p class="text-sm font-medium text-gray-900">Create Server</p>
          <p class="truncate text-sm text-gray-500">Add a new server to the cluster</p>
        </div>
      <% end %>

      <%= link_to "#", class: "relative flex items-center space-x-3 rounded-lg border border-gray-200 bg-white px-6 py-5 hover:border-gray-300 hover:shadow" do %>
        <div class="flex-shrink-0">
          <div
            class="
              inline-flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600
            "
          >
            <svg
              class="h-6 w-6 text-white"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99"
              />
            </svg>
          </div>
        </div>
        <div class="min-w-0 flex-1">
          <span class="absolute inset-0" aria-hidden="true"></span>
          <p class="text-sm font-medium text-gray-900">Upgrade Cluster</p>
          <p class="truncate text-sm text-gray-500">Update to the latest version</p>
        </div>
      <% end %>

      <%= link_to "#", class: "relative flex items-center space-x-3 rounded-lg border border-gray-200 bg-white px-6 py-5 hover:border-gray-300 hover:shadow" do %>
        <div class="flex-shrink-0">
          <div
            class="
              inline-flex h-10 w-10 items-center justify-center rounded-lg bg-indigo-600
            "
          >
            <svg
              class="h-6 w-6 text-white"
              fill="none"
              viewBox="0 0 24 24"
              stroke-width="1.5"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z"
              />
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
              />
            </svg>
          </div>
        </div>
        <div class="min-w-0 flex-1">
          <span class="absolute inset-0" aria-hidden="true"></span>
          <p class="text-sm font-medium text-gray-900">Configure Cluster</p>
          <p class="truncate text-sm text-gray-500">Manage cluster settings</p>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# Recent Apps and Deployments Grid %>
<div class="mt-8 grid grid-cols-1 gap-8 lg:grid-cols-2">
  <%# Servers %>
  <div class="overflow-hidden rounded-lg bg-white border border-gray-200">
    <div class="p-6">
      <div class="sm:flex sm:items-center">
        <div class="sm:flex-auto">
          <h3 class="text-base font-semibold leading-6 text-gray-900">Servers</h3>
          <p class="mt-1 text-sm text-gray-500">Servers in this cluster</p>
        </div>
        <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
          <%= link_to "View all", "#", 
              class: "block rounded-md bg-indigo-600 px-3 py-2 text-center text-sm font-semibold text-white hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
        </div>
      </div>
      <div class="mt-6 flow-root">
        <div class="-mx-4 -my-2 overflow-x-auto sm:-mx-6 lg:-mx-8">
          <div class="inline-block min-w-full py-2 align-middle">
            <table class="min-w-full divide-y divide-gray-300">
              <thead>
                <tr>
                  <th scope="col" class="py-3.5 pl-4 pr-3 text-left text-sm font-semibold text-gray-900 sm:pl-6 lg:pl-8">Name</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Status</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">Type</th>
                  <th scope="col" class="px-3 py-3.5 text-left text-sm font-semibold text-gray-900">IPv4</th>
                  <th scope="col" class="relative py-3.5 pl-3 pr-4 sm:pr-6 lg:pr-8">
                    <span class="sr-only">View</span>
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-200 bg-white">
                
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Recent Events %>
  <div>
    <%= render "dashboard/recent_events", recent_task_executions: @recent_task_executions %>
  </div>
</div>

