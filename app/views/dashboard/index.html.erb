    <dd class="ml-16 flex items-baseline pb-6 sm:pb-7">
      <p class="text-2xl font-semibold text-gray-900">0</p>
      <div class="absolute inset-x-0 bottom-0 bg-gray-50 px-4 py-4 sm:px-6">
        <%= link_to "#", class: "text-sm font-medium text-indigo-600 hover:text-indigo-500" do %>
          View applications<span class="sr-only">
            Running Applications</span>
        <% end %>
      </div>
    </dd>
  </div>

  <div
    class="
      relative overflow-hidden rounded-lg bg-white border border-gray-200
      px-4 pb-12 pt-5 sm:px-6 sm:pt-6
    "
  >
    <dt>
      <div class="absolute rounded-md bg-indigo-500 p-3">
        <svg
          class="h-6 w-6 text-white"
          fill="none"
          viewBox="0 0 24 24"
          stroke-width="1.5"
          stroke="currentColor"
