<div id="recent_events" class="overflow-hidden rounded-lg bg-white shadow-sm border border-gray-200">
  <div class="p-6">
    <div class="sm:flex sm:items-center">
      <div class="sm:flex-auto">
        <h3 class="text-base font-semibold leading-6 text-gray-900">Recent Events</h3>
        <p class="mt-1 text-sm text-gray-500">Latest task executions and changes</p>
      </div>
      <div class="mt-4 sm:ml-16 sm:mt-0 sm:flex-none">
        <%= link_to "View all", task_executions_path, class: "block rounded-md bg-indigo-600 px-3 py-2 text-center text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" %>
      </div>
    </div>
    <div class="mt-6 flow-root">
      <ul role="list" class="-mb-8">
        <% recent_task_executions.each do |execution| %>
          <li>
            <div class="relative pb-8">
              <span class="absolute left-5 top-5 -ml-px h-full w-0.5 bg-gray-200" aria-hidden="true"></span>
              <div class="relative flex items-start space-x-3">
                <div class="relative">
                  <div class="flex h-10 w-10 items-center justify-center rounded-full <%= status_ring_class(execution.status) %> ring-8 ring-white">
                    <%= status_icon(execution.status) %>
                  </div>
                </div>
                <div class="min-w-0 flex-1">
                  <div>
                    <div class="text-sm">
                      <span class="font-medium text-gray-900">
                        <%= link_to t("tasks.#{execution.task_class.underscore}.label", default: execution.task_class), task_execution_path(execution) %>
                      </span>
                    </div>
                    <div class="flex items-center gap-2">
                      <span class="<%= status_badge_class(execution.status) %>">
                        <%= execution.status.titleize %>
                        <% if execution.status == "running" %>
                          <svg class="animate-spin h-3 w-3 ml-1 inline-block" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                          </svg>
                        <% end %>
                      </span>
                      <% if execution.status == "failed" && execution.error_message.present? %>
                        <span class="ml-2 text-xs text-gray-500 break-words max-w-[400px]"><%= execution.error_message %></span>
                      <% elsif execution.status == "success" %>
                        <span class="ml-2 text-xs text-gray-500">Completed</span>
                      <% elsif execution.status == "running" && execution.task_action_logs.any? %>
                        <span class="ml-2 text-xs text-gray-500">
                          <span class="font-medium">Current step:</span> 
                          <% current_step = execution.task_action_logs.find_by(status: "running") || execution.task_action_logs.order(step_index: :desc).first %>
                          <%= current_step&.step_label %>
                        </span>
                      <% end %>
                    </div>
                  </div>
                  <div class="mt-2 text-sm text-gray-500">
                    <% if execution.started_at.present? %>
                      <time datetime="<%= execution.started_at.iso8601 %>">
                        <%= time_ago_in_words(execution.started_at) %> ago
                      </time>
                    <% else %>
                      <span>Queued</span>
                    <% end %>
                  </div>
                </div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>

<%# Helper methods for status styling %>
<% def status_ring_class(status) %>
  <% case status %>
  <% when "success" %>
    bg-green-100
  <% when "failed" %>
    bg-red-100
  <% when "running" %>
    bg-blue-100
  <% else %>
    bg-gray-100
  <% end %>
<% end %>

<% def status_icon(status) %>
  <% case status %>
  <% when "success" %>
    <svg class="h-5 w-5 text-green-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
  <% when "failed" %>
    <svg class="h-5 w-5 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
    </svg>
  <% when "running" %>
    <svg class="h-5 w-5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0l3.181 3.183a8.25 8.25 0 0013.803-3.7M4.031 9.865a8.25 8.25 0 0113.803-3.7l3.181 3.182m0-4.991v4.99" />
    </svg>
  <% else %>
    <svg class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
    </svg>
  <% end %>
<% end %>

<% def status_badge_class(status) %>
  <% case status %>
  <% when "success" %>
    inline-flex items-center rounded-md bg-green-50 px-2 py-1 text-xs font-medium text-green-700 ring-1 ring-inset ring-green-600/20
  <% when "failed" %>
    inline-flex items-center rounded-md bg-red-50 px-2 py-1 text-xs font-medium text-red-700 ring-1 ring-inset ring-red-600/20
  <% when "running" %>
    inline-flex items-center rounded-md bg-blue-50 px-2 py-1 text-xs font-medium text-blue-700 ring-1 ring-inset ring-blue-600/20
  <% else %>
    inline-flex items-center rounded-md bg-gray-50 px-2 py-1 text-xs font-medium text-gray-700 ring-1 ring-inset ring-gray-600/20
  <% end %>
<% end %> 